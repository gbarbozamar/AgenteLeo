# HTTP server
PORT=3000

# Security — bearer token required for MCP clients
MCP_BEARER_TOKEN=<GENERATE-A-LONG-RANDOM-STRING>

# WhatsApp
WA_SESSION_NAME=openclaw-main
OWNER_JID=+5491112345678              # full international format, no spaces

# Storage (Railway mounts a volume at /data)
AUTH_DIR=./auth_info
DB_PATH=./data/messages.db

# Logging
LOG_LEVEL=info

# Rate limits (per client/token)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
